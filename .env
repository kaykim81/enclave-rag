# ── dev profile — this VM (4 vCPU / 15GB / no swap) ──
# Auto-loaded by `docker compose`. The prod overlay is .env.prod (task 0.6).

DATA_DIR=/data/rag

# Models (pulled via `ollama pull` in Phase 1)
GEN_MODEL=qwen3:4b
EMBED_MODEL=nomic-embed-text

# Inference tuning
OLLAMA_NUM_THREAD=4

# Per-service memory caps — hard caps (no swap), so a runaway container OOMs itself,
# not the host. Active services sum to ~9g of 15g; +3g when the app services land.
OLLAMA_MEM_LIMIT=6g
QDRANT_MEM_LIMIT=2g
WEBUI_MEM_LIMIT=1g
RAGAPI_MEM_LIMIT=1500m
INGEST_MEM_LIMIT=1500m

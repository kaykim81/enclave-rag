# ── prod profile — R360 (Xeon E-2468 8C/16T / 32GB / LVM) ──
# Overlay for the deploy target. Use with: `docker compose --env-file .env.prod ...`
# (--env-file REPLACES the default .env, so this file is self-contained.)
#
# INVARIANT: identical service topology to dev. This overlay changes ONLY
# model, embedder, threads, volume source, and mem_limits — nothing else.

DATA_DIR=/data/rag                # same path as dev; on the R360 this is an LVM mount (fstab), not a plain dir

# Models (pulled via `ollama pull` in Phase 7)
GEN_MODEL=qwen3:8b                # dev qwen3:4b → prod qwen3:8b (32GB holds it)
EMBED_MODEL=bge-m3               # dev nomic-embed-text → prod bge-m3 (sparse vectors for hybrid search)

# Inference tuning
OLLAMA_NUM_THREAD=8               # dev 4 vCPUs → prod 8 cores

# Per-service memory caps — sized for 32GB (dev was sized for 15GB, no swap).
# ollama holds qwen3:8b + bge-m3 + bge-reranker-v2-m3 co-resident (Phase 7/8).
# Active services sum to ~28g of 32g, leaving ~4g host headroom.
OLLAMA_MEM_LIMIT=14g
QDRANT_MEM_LIMIT=6g
WEBUI_MEM_LIMIT=2g
RAGAPI_MEM_LIMIT=3g
INGEST_MEM_LIMIT=3g
